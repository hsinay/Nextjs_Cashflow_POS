// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PayerType {
  CUSTOMER
  SUPPLIER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  UPI
  CHEQUE
  DIGITAL_WALLET
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  POS_SALE
}

enum POSSessionStatus {
  OPEN
  CLOSED
  SUSPENDED
}

enum TransactionPaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  DIGITAL_WALLET
  MIXED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum POSPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}


model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  password      String // bcrypt hashed
  contactNumber String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  roles UserRole[]
  posSessions POSSession[]
  transactions Transaction[]

  @@index([username])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // ADMIN, INVENTORY_MANAGER, etc.
  description String?
  permissions Json // Array of permission strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users UserRole[]

  @@index([name])
  @@map("roles")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Category {
  id               String   @id @default(uuid())
  name             String   @unique
  isActive         Boolean  @default(true)
  description      String?
  imageUrl         String?
  parentCategoryId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Self-referencing relation for hierarchical structure
  parent   Category?  @relation("CategoryParent", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")

  // Relations to other entities
  products Product[]

  @@index([name])
  @@index([parentCategoryId])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  name            String
  description     String?
  sku             String?  @unique
  barcode         String?
  imageUrl        String?
  price           Decimal  @db.Decimal(12, 2)
  costPrice       Decimal? @db.Decimal(12, 2)
  stockQuantity   Int      @default(0)
  reorderLevel    Int?
  taxRate         Decimal? @db.Decimal(5, 2)
  isActive        Boolean  @default(true)
  categoryId      String
  aiTags          String[] @default([])
  visionEmbedding Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  category             Category @relation(fields: [categoryId], references: [id])
  salesOrderItems      SalesOrderItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  inventoryTransactions InventoryTransaction[]
  transactionItems     TransactionItem[]

  @@index([categoryId])
  @@index([name])
  @@index([sku])
  @@index([barcode])
  @@map("products")
}


model InventoryTransaction {
  id              String    @id @default(uuid())
  productId       String
  transactionType InventoryTransactionType
  quantity        Int
  transactionDate DateTime  @default(now())
  notes           String?
  unitCost        Decimal?  @db.Decimal(12, 2)
  referenceId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([transactionType])
  @@map("inventory_transactions")
}


model Customer {
  id              String   @id @default(uuid())
  name            String
  email           String?  @unique
  contactNumber   String?
  billingAddress  String?
  shippingAddress String?
  creditLimit     Decimal  @default(0) @db.Decimal(12, 2)
  loyaltyPoints   Int      @default(0)
  aiSegment       String   @default("NEW")
  churnRiskScore  Decimal? @db.Decimal(4, 3)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  salesOrders SalesOrder[]
  payments    Payment[]    @relation("CustomerPayments")
  transactions Transaction[]

  @@index([name])
  @@index([email])
  @@index([contactNumber])
  @@map("customers")
}

model SalesOrder {
  id                  String           @id @default(uuid())
  customerId          String
  orderDate           DateTime         @default(now())
  status              SalesOrderStatus @default(DRAFT)
  totalAmount         Decimal          @db.Decimal(12, 2)
  balanceAmount       Decimal          @db.Decimal(12, 2)
  aiUpsellSuggestions String[]         @default([])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  customer Customer         @relation(fields: [customerId], references: [id])
  items    SalesOrderItem[]

  @@index([customerId])
  @@index([status])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String   @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([salesOrderId])
  @@index([productId])
  @@map("sales_order_items")
}

model Payment {
  id               String        @id @default(uuid())
  payerId          String
  payerType        PayerType
  paymentDate      DateTime      @default(now())
  amount           Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  referenceOrderId String?
  paymentInsights  String?
  referenceNumber  String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt @map("updatedAt")

  // Explicit relations for easier querying, application logic ensures consistency
  customer  Customer? @relation("CustomerPayments", fields: [payerId], references: [id], onDelete: Restrict, map: "fk_payment_customer_payerId")
  supplier  Supplier? @relation("SupplierPayments", fields: [payerId], references: [id], onDelete: Restrict, map: "fk_payment_supplier_payerId")


  @@index([payerId])
  @@index([paymentMethod])
  @@map("payments")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  email         String?  @unique
  contactNumber String?
  address       String?
  creditLimit   Decimal  @default(0) @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  purchaseOrders PurchaseOrder[]
  payments       Payment[] @relation("SupplierPayments")

  @@index([name])
  @@index([email])
  @@index([contactNumber])
  @@map("suppliers")
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  supplierId    String
  orderDate     DateTime            @default(now())
  status        PurchaseOrderStatus @default(DRAFT)
  totalAmount   Decimal             @db.Decimal(12, 2)
  balanceAmount Decimal             @db.Decimal(12, 2)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  discount        Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model POSSession {
  id                String            @id @default(uuid())
  cashierId         String
  terminalId        String?
  status            POSSessionStatus  @default(OPEN)
  openingCashAmount Decimal           @db.Decimal(12, 2)
  closingCashAmount Decimal?          @db.Decimal(12, 2)
  totalSalesAmount  Decimal           @default(0) @db.Decimal(12, 2)
  totalCashReceived Decimal           @default(0) @db.Decimal(12, 2)
  totalCardReceived Decimal           @default(0) @db.Decimal(12, 2)
  totalDigitalReceived Decimal        @default(0) @db.Decimal(12, 2)
  totalTransactions Int               @default(0)
  cashVariance      Decimal           @default(0) @db.Decimal(12, 2)
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  cashier     User         @relation(fields: [cashierId], references: [id])
  transactions Transaction[]

  @@index([cashierId])
  @@index([status])
  @@map("pos_sessions")
}

model Transaction {
  id                    String                   @id @default(uuid())
  transactionNumber     String                   @unique
  customerId            String?
  cashierId             String
  sessionId             String?
  totalAmount           Decimal                  @db.Decimal(12, 2)
  taxAmount             Decimal                  @default(0) @db.Decimal(12, 2)
  discountAmount        Decimal                  @default(0) @db.Decimal(12, 2)
  paymentMethod         TransactionPaymentMethod
  status                TransactionStatus        @default(PENDING)
  loyaltyPointsEarned   Int                      @default(0)
  loyaltyPointsRedeemed Int                      @default(0)
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  customer       Customer?        @relation(fields: [customerId], references: [id])
  cashier        User             @relation(fields: [cashierId], references: [id])
  session        POSSession?      @relation(fields: [sessionId], references: [id])
  items          TransactionItem[]
  paymentDetails POSPaymentDetail[]
  receipt        Receipt?

  @@index([transactionNumber])
  @@index([customerId])
  @@index([cashierId])
  @@index([sessionId])
  @@index([status])
  @@map("transactions")
}

model TransactionItem {
  id              String   @id @default(uuid())
  transactionId   String
  productId       String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  discountApplied Decimal  @default(0) @db.Decimal(12, 2)
  taxRate         Decimal? @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

model POSPaymentDetail {
  id              String             @id @default(uuid())
  transactionId   String
  paymentMethod   TransactionPaymentMethod
  amount          Decimal            @db.Decimal(12, 2)
  referenceNumber String?
  status          POSPaymentStatus   @default(COMPLETED)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([paymentMethod])
  @@map("pos_payment_details")
}

model Receipt {
  id           String    @id @default(uuid())
  transactionId String    @unique
  receiptNumber String    @unique
  receiptData   String?
  printCount    Int       @default(0)
  lastPrintedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model LedgerEntry {
  id            String    @id @default(uuid())
  entryDate     DateTime  @default(now())
  description   String
  debitAccount  String
  creditAccount String
  amount        Decimal   @db.Decimal(12, 2)
  referenceId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([entryDate])
  @@index([debitAccount])
  @@index([creditAccount])
  @@map("ledger_entries")
}